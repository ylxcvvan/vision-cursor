  <property name="styleSheet">
   <string notr="true">QWidget#MonitorPage {
    background-color: transparent;
    color: #1f2937;
    font-family: &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

QFrame#frameTitle,
QFrame#frameStatusInfo {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 14px;
}

QGroupBox {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 14px;
    margin-top: 10px;
    font-size: 13px;
    font-weight: 600;
    color: #1f2937;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px 0 6px;
    color: #334155;
}

QLabel#labelPageTitle {
    color: #1f2937;
    font-size: 22px;
    font-weight: 700;
}

QLabel#labelPageHint {
    color: #6b7280;
    font-size: 12px;
}

QPushButton {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 12px;
    padding: 8px 14px;
    color: #1f2937;
    font-size: 13px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #eef4ff;
    border: 1px solid #bfdbfe;
}

QPushButton:pressed {
    background-color: #dbeafe;
}

QPushButton#btnPreviewMode {
    background-color: #ffffff;
}

QPushButton#btnDebugMode {
    background-color: #ffffff;
}

QPushButton#btnFullMode {
    background-color: #ffffff;
}

QLabel#labelVideo {
    background-color: #f8fafc;
    border: 1px dashed #9db6da;
    border-radius: 16px;
    color: #6b7280;
    font-size: 14px;
    padding: 8px;
}

QLabel[role=&quot;statusName&quot;] {
    color: #6b7280;
    font-size: 12px;
    font-weight: 500;
}

QLabel[role=&quot;statusValue&quot;] {
    color: #1f2937;
    font-size: 13px;
    font-weight: 700;
    background-color: #f8fafc;
    border: 1px solid #e5edf6;
    border-radius: 8px;
    padding: 4px 8px;
}

QPlainTextEdit#plainTextLog {
    background-color: #0f172a;
    color: #e5eefb;
    border: 1px solid #1e293b;
    border-radius: 12px;
    padding: 8px;
    font-family: Consolas, &quot;Courier New&quot;, monospace;
    font-size: 12px;
}</string>
