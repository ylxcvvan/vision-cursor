  <property name="styleSheet">
   <string notr="true">
   QWidget#SettingPage {
    background-color: #ffffff;   
    color: #1f2937;
    font-family: &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

QFrame#frameTitle,
QFrame#frameBottomButtons,
QFrame#frameCameraConfig,
QFrame#frameMapperBasic {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 14px;
}

QGroupBox {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 10px;
    margin-top: 10px;
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 2px 8px;
    color: #1f2937;
    font-size: 14px;
    font-weight: 600;
}

QLabel#labelPageTitle {
    color: #1f2937;
    font-size: 22px;
    font-weight: 700;
}

QLabel#labelPageHint,
QLabel#labelBottomHint {
    color: #6b7280;
    font-size: 12px;
}

QLabel[role=&quot;fieldName&quot;] {
    color: #374151;
    font-size: 13px;
    font-weight: 600;
}

QLineEdit,
QComboBox,
QSpinBox,
QDoubleSpinBox {
    min-height: 30px;
    background-color: #ffffff;
    border: 1px solid #cfd8e3;
    border-radius: 8px;
    color: #111827;
    font-size: 14px;
}

QLineEdit {
    padding: 5px 10px;
}

QLineEdit:hover,
QComboBox:hover,
QSpinBox:hover,
QDoubleSpinBox:hover {
    border: 1px solid #93c5fd;
}

QLineEdit:focus,
QComboBox:focus,
QSpinBox:focus,
QDoubleSpinBox:focus {
    border: 1px solid #2563eb;
    background-color: #ffffff;
}

QComboBox {
    padding: 5px 28px 5px 10px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 26px;
    background-color: #e9eef5;
    border-left: 1px solid #cfd8e3;
    border-top-right-radius: 7px;
    border-bottom-right-radius: 7px;
}

QComboBox::drop-down:hover {
    background-color: #dbeafe;
}

QComboBox::drop-down:pressed {
    background-color: #bfdbfe;
}

QComboBox::down-arrow {
    width: 9px;
    height: 9px;
}

QSpinBox,
QDoubleSpinBox {
    padding: 5px 40px 5px 10px;
    font-weight: 600;
}

QSpinBox::up-button,
QDoubleSpinBox::up-button,
QSpinBox::down-button,
QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    width: 20px;
    background-color: #c9d4e2;
    border-left: 1px solid #b4c0cf;
}

QSpinBox::up-button,
QDoubleSpinBox::up-button {
    subcontrol-position: top right;
    border-top-right-radius: 7px;
    border-bottom: 1px solid #9fb0c4;
    margin: 1px 1px 0 0;
}

QSpinBox::down-button,
QDoubleSpinBox::down-button {
    subcontrol-position: bottom right;
    border-bottom-right-radius: 7px;
    border-top: 1px solid #dfe7f0;
    margin: 0 1px 1px 0;
}

QSpinBox::up-button:hover,
QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover,
QDoubleSpinBox::down-button:hover {
    background-color: #b8d4fb;
}

QSpinBox::up-button:pressed,
QDoubleSpinBox::up-button:pressed,
QSpinBox::down-button:pressed,
QDoubleSpinBox::down-button:pressed {
    background-color: #93c5fd;
}

QPushButton {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 10px;
    padding: 7px 14px;
    color: #1f2937;
    font-size: 14px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #eef4ff;
    border: 1px solid #bfdbfe;
}

QPushButton:pressed {
    background-color: #dbeafe;
}

QCheckBox {
    color: #1f2937;
    font-size: 13px;
}

QScrollArea {
    border: none;
    background: transparent;
}

QStackedWidget#stackedWidgetFilterParams {
    border: 1px solid #e5edf6;
    border-radius: 8px;
}</string>
